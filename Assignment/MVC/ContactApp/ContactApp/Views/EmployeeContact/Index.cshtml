@model IEnumerable<MvcAsyncDemo.Models.EmployeeContact>

@{
    ViewBag.Title = "Index";
}

<h2>Employee Contact List</h2>

<p>
    @Html.ActionLink("Add Contact", "Create")
</p>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>@item.Email</td>

            <td>
                @Html.ActionLink("Delete", "Delete",
                new { id = item.Id })
            </td>
        </tr>
    }

</table>